# ==========================================
# OpenClawGotchi V3 — Primary Configuration
# ==========================================
# Copy this file to .env and fill in your values
# Run 'gotchi setup' to automatically configure these values.

# --- Bot Identity ---
BOT_NAME=Gotchi
OWNER_NAME=Owner
BOT_LANGUAGE=en

# --- Bot Platform ---
# Options: discord, telegram
BOT_PLATFORM=discord

# --- Discord Configuration ---
DISCORD_BOT_TOKEN=your_discord_token_here
DISCORD_ALLOWED_USERS=123456789
DISCORD_CHANNEL_ID=1508214633817702641
DISCORD_HEARTBEATS_CHANNEL=1509744550141366342
DARK_MODE=0

# --- Telegram Configuration ---
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ALLOWED_USERS=123456789
ALLOWED_GROUPS=-1001234567890
GROUP_CHAT_ID=0

# ==========================================
# 🧠 AI Backend Core Configuration
# ==========================================
# OpenClawGotchi uses a dual-mode routing architecture:
# - Lite Mode (Default): Fast, conversational reasoning via LiteLLM.
# - Pro Mode (Advanced): Deep reasoning via native CLI tools.

DEFAULT_LITE_PRESET=gemini
DEFAULT_LITE_MODEL=gemini-1.5-flash
DEFAULT_PRO_PRESET=gemini
DEFAULT_PRO_MODEL=gemini-1.5-pro
CLAUDE_TIMEOUT=600

# --- Subconscious Tools & Memory ---
# Enables the LLM to run bash commands, read/write files, and modify its workspace.
# Highly recommended for true OpenClaw capability (Default is 1).
ENABLE_LITELLM_TOOLS=1
MODEL_CONTEXT_TOKENS=128000
HISTORY_LIMIT=10

# =============================================================================
# EXHAUSTIVE LLM PROVIDERS (via LiteLLM / Custom Connectors)
# =============================================================================

# =============================================================================
# LLM PROVIDER (OpenRouter)
# =============================================================================
# OpenRouter provides access to many models through one API
# All LLM calls go through OpenRouter - no direct provider keys needed
# Get your key at: https://openrouter.ai/keys
# OPENROUTER_API_KEY=

# =============================================================================
# LLM PROVIDER (NovitaAI)
# =============================================================================
# NovitaAI — 90+ models, pay-per-use
# Get your key at: https://novita.ai/settings/key-management
# NOVITA_API_KEY=
# NOVITA_BASE_URL=https://api.novita.ai/openai/v1  # Override default base URL

# =============================================================================
# LLM PROVIDER (Google AI Studio / Gemini)
# =============================================================================
# Native Gemini API via Google's OpenAI-compatible endpoint.
# Get your key at: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your_gemini_key_here
# GOOGLE_API_KEY=your_gemini_key_here  # alias for GEMINI_API_KEY
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# =============================================================================
# LLM PROVIDER (Ollama Cloud & Local)
# =============================================================================
# Cloud-hosted open models via Ollama's OpenAI-compatible endpoint.
# Get your key at: https://ollama.com/settings
# OLLAMA_API_KEY=your_ollama_key_here
# OLLAMA_BASE_URL=https://ollama.com/v1

# For local SSH remote tunneling:
# OLLAMA_BASE_URL=http://localhost:11434

# =============================================================================
# LLM PROVIDER (z.ai / GLM)
# =============================================================================
# z.ai provides access to ZhipuAI GLM models (GLM-4-Plus, etc.)
# Get your key at: https://z.ai or https://open.bigmodel.cn
# ZAI_API_KEY=
# GLM_API_KEY=  # alias
# GLM_BASE_URL=https://api.z.ai/api/paas/v4  # Override default base URL

# =============================================================================
# LLM PROVIDER (Kimi / Moonshot)
# =============================================================================
# Kimi Code provides access to Moonshot AI coding models (kimi-k2.5, etc.)
# Get your key at: https://platform.kimi.ai (Kimi Code console)
# MOONSHOT_API_KEY=
# KIMI_API_KEY= # alias
# KIMI_BASE_URL=https://api.kimi.com/coding/v1  # Default for sk-kimi- keys

# =============================================================================
# LLM PROVIDER (Arcee AI)
# =============================================================================
# Arcee AI provides access to Trinity models (trinity-mini, trinity-large-*)
# Get an Arcee key at: https://chat.arcee.ai/
# ARCEEAI_API_KEY=

# =============================================================================
# LLM PROVIDER (MiniMax)
# =============================================================================
# MiniMax provides access to MiniMax models (global endpoint)
# Get your key at: https://www.minimax.io
# MINIMAX_API_KEY=

# =============================================================================
# LLM PROVIDER (OpenCode Zen & Go)
# =============================================================================
# OpenCode Zen provides curated, tested models. Get your key at: https://opencode.ai/auth
# OPENCODE_ZEN_API_KEY=
# OPENCODE_GO_API_KEY=

# =============================================================================
# LLM PROVIDER (Hugging Face Inference Providers)
# =============================================================================
# Hugging Face routes to 20+ open models via unified OpenAI-compatible endpoint.
# Get your token at: https://huggingface.co/settings/tokens
# HUGGINGFACE_API_KEY=
# HF_TOKEN= # alias

# =============================================================================
# LLM PROVIDER (Xiaomi MiMo)
# =============================================================================
# Xiaomi MiMo models (mimo-v2-pro, mimo-v2-omni, mimo-v2-flash).
# Get your key at: https://platform.xiaomimimo.com
# XIAOMI_API_KEY=

# =============================================================================
# LLM PROVIDER (DeepSeek)
# =============================================================================
# DeepSeek native API models (V3, R1, Coder).
# DEEPSEEK_API_KEY=

# =============================================================================
# LLM PROVIDER (Anthropic)
# =============================================================================
# Anthropic native API. 
# NOTE: Required for LiteLLM Anthropic calls to prevent Auth Error 1001.
# ANTHROPIC_API_KEY=

# =============================================================================
# LLM PROVIDER (OpenAI & xAI)
# =============================================================================
# OPENAI_API_KEY=
# XAI_API_KEY=
# NOUS_API_KEY=
# DASHSCOPE_API_KEY=
# TENCENT_API_KEY=
# NVIDIA_API_KEY=
# GITHUB_TOKEN=

# ==========================================
# ⚔️ Pwnagotchi Hardware Subsystem
# ==========================================
# Set to 'true' to automatically enter monitor mode and start hunting on boot
HUNT_ON_BOOT=false

# Subconscious API config
BETTERCAP_URL=http://localhost:8081/api
BETTERCAP_USER=gotchi
BETTERCAP_PASS=123456

# Comma-separated MAC addresses to NEVER attack (e.g. your home router)
PWN_WHITELIST_MACS=
WPA_SEC_KEY=

# ==========================================
# 🌐 External Integrations & Tools (Optional)
# ==========================================
# Search capabilities for the Agent
# BRAVE_SEARCH_API_KEY=

# Exa API Key - AI-native web search and contents
# Get at: https://exa.ai
# EXA_API_KEY=

# Parallel API Key - AI-native web search and extract
# Get at: https://parallel.ai
# PARALLEL_API_KEY=

# Firecrawl API Key - Web search, extract, and crawl
# Get at: https://firecrawl.dev/
# FIRECRAWL_API_KEY=

# FAL.ai API Key - Image generation
# Get at: https://fal.ai/
# FAL_KEY=

# Agent GitHub Personal Access Token (for repo modifications)
AGENT_GITHUB_PAT=
